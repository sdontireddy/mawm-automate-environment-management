# Manhattan WMS API Configuration
MAWM_BASE_URL=https://XXXX.sce.manh.com/device-integration/api

# Custom Headers for Environment Differentiation
# These headers determine which environment ({{Location}}, {{Location}}, {{Location}}QA, etc.) is targeted
MAWM_LOCATION={{Location}}
MAWM_ORGANIZATION={{Location}}

# For dual environment operations (cloning from source to destination)
SOURCE_LOCATION={{Location}}
SOURCE_ORGANIZATION={{Location}}
DESTINATION_LOCATION={{Location}}
DESTINATION_ORGANIZATION={{Location}}

# Authentication Type (basic, bearer, api_key, oauth)
AUTH_TYPE=oauth

# OAuth 2.0 Configuration (for MAWM OAuth authentication)
OAUTH_TOKEN_URL=https://XXXX-auth.sce.manh.com/oauth/token
OAUTH_CLIENT_ID=omnicomponent.1.0.0
OAUTH_CLIENT_SECRET=XXXXX
OAUTH_USERNAME=sdontireddy
OAUTH_PASSWORD=XXXXX
OAUTH_GRANT_TYPE=password

# Environment Headers (determines {{Location}} vs {{Location}} vs {{Location}}QA)
# Destination environment headers
LOCATION={{Location}}
ORGANIZATION={{Location}}

# Source environment headers (for cloning operations)
SOURCE_LOCATION={{Location}}
SOURCE_ORGANIZATION={{Location}}

# Golden Environment OAuth (if different from default)
# Leave empty to use same credentials as above
GOLDEN_OAUTH_USERNAME=
GOLDEN_OAUTH_PASSWORD=
GOLDEN_OAUTH_CLIENT_ID=
GOLDEN_OAUTH_CLIENT_SECRET=

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=5
TIMEOUT=30

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=true

# Environment
DEFAULT_ENVIRONMENT=dev
